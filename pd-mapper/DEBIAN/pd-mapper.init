#!/bin/sh
### BEGIN INIT INFO
# Provides:          pd-mapper
# Required-Start:    $remote_fs $syslog
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Qualcomm PD mapper
### END INIT INFO

case "$1" in
  start)
    /usr/bin/pd-mapper &
    ;;
  stop)
    killall pd-mapper
    ;;
esac

exit 0